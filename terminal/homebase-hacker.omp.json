{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 3,
  "final_space": true,
  "console_title_template": "HOME BASE // {{ .Folder }} — {{ .UserName }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "leading_diamond": "\u256d\u2500",
          "foreground": "#1a1b26",
          "background": "#9ece6a",
          "template": " \uf120 "
        },
        {
          "type": "command",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#bb9af7",
          "properties": {
            "shell": "pwsh",
            "command": "pwsh -NoProfile -File C:/Scripts/Workstation/terminal/omp-genesis.ps1",
            "cache_duration": "5m"
          },
          "template": " {{ .Output }} "
        },
        {
          "type": "command",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#7aa2f7",
          "properties": {
            "shell": "pwsh",
            "command": "pwsh -NoProfile -File C:/Scripts/Workstation/terminal/omp-trust.ps1",
            "cache_duration": "1m"
          },
          "template": " {{ .Output }} "
        },
        {
          "type": "command",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#565f89",
          "properties": {
            "shell": "pwsh",
            "command": "pwsh -NoProfile -File C:/Scripts/Workstation/terminal/omp-health.ps1",
            "cache_duration": "2m"
          },
          "template": " {{ .Output }} "
        },
        {
          "type": "session",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#73daca",
          "template": " {{ .UserName }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#c0caf5",
          "background": "#24283b",
          "properties": {
            "style": "folder",
            "max_depth": 3,
            "folder_separator_icon": " \ue0b1 ",
            "home_icon": "~"
          }
        },
        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#bb9af7",
          "properties": { "branch_icon": "\ue725 ", "fetch_status": false }
        },
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "#1a1b26",
          "background": "#e0af68",
          "properties": { "threshold": 2000, "style": "round" }
        },
        {
          "type": "status",
          "style": "diamond",
          "trailing_diamond": "\u256f",
          "foreground": "#1a1b26",
          "background": "#f7768e",
          "properties": { "always_enabled": true }
        }
      ]
    }
  ],
  "transient_prompt": {
    "foreground": "#9ece6a",
    "background": "transparent",
    "template": "\u276f "
  },
  "secondary_prompt": {
    "foreground": "#565f89",
    "background": "transparent",
    "template": "\u276f "
  }
}
